<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with all field values in lowercase. All element
comparisons are case-insensitive (§5.7). The expected outcome is a conforming
locationValidation result identical to the equivalent mixed-case request, confirming
that case-insensitive comparison applies throughout the progressive filter. The civic
address matches a provisioned SSAP record.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>us</country>
      <A1>nd</A1>
      <A2>burleigh county</A2>
      <A3>bismarck</A3>
      <RD>capitol</RD>
      <STS>way</STS>
      <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
