<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address for Capitol Way with a prefix direction
(PRD=North). No provisioned GIS record for Capitol Way carries a directional prefix.
Gate 2 fails at ca:PRD; subsequent submitted elements (ca:STS, ca:HNO) are
<unchecked> per the stop-on-first-invalid rule (§5.8).
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr" xml:lang="en-US" >
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
	    <PRD>North</PRD>
      <RD>Capitol</RD>
	    <STS>Way</STS>
	    <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>