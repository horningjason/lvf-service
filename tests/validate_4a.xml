<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with an out-of-coverage country code (CA).
Gate 2 fails at ca:country; all remaining submitted elements are <unchecked> per
the stop-on-first-invalid rule.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr" xml:lang="en-US" >
      <country>CA</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
	    <STS>Way</STS>
	    <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>