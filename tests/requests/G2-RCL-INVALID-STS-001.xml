<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address for 3401 State Street, Bismarck with an
incorrect street suffix (STS=Avenue). The SSAP record for this address has
STS=Street. Gate 2 fails at ca:STS; subsequent submitted elements (ca:HNO,
ca:HNS) are flushed to <unchecked> per the stop-on-first-invalid rule.

Expected: valid=[ca:country, ca:A1, ca:A2, ca:A3, ca:RD]
          invalid=[ca:STS]
          unchecked=[ca:HNO, ca:HNS]
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>State</RD>
      <STS>Avenue</STS>
      <HNO>3401</HNO>
      <HNS>B</HNS>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
