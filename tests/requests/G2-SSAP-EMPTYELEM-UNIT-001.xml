<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with an explicitly empty UNIT_VALUE element
(tag present, no text content). An empty element matches a GIS field that
is null or empty. The expected outcome is a conforming locationValidation result
with UNIT_VALUE appearing in <valid>, confirming the empty-element match behavior.
The civic address matches a provisioned SSAP record.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr"
                  xmlns:cdx2="urn:nena:xml:ns:pidf:nenaCivicAddr2"
                  xml:lang="en-US">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
      <cdx2:UNIT_VALUE></cdx2:UNIT_VALUE>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>