<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with sub-unit elements (UNIT_PRETYPE=Unit,
UNIT_VALUE=11) at an address for which no matching SSAP record exists for this specific
unit. The civic address has a non-conforming STP element which should have been prepended
with cae.  The expected outcome is a badRequest due to schema violation.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr" 
                  xmlns:cdx2="urn:nena:xml:ns:pidf:nenaCivicAddr2"
                  xml:lang="en-US" >
      <country>US</country>
      <A1>ND</A1>
      <A2>Mercer County</A2>
      <A3>Beulah</A3>
      <RD>3RD</RD>
      <STS>Avenue</STS>
      <STP>Northwest</STP>
      <HNO>205</HNO>
      <cdx2:UNIT_PRETYPE>Unit</cdx2:UNIT_PRETYPE>
      <cdx2:UNIT_VALUE>11</cdx2:UNIT_VALUE>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>