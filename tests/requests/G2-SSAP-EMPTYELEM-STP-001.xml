<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with an explicitly empty STP element (tag present,
no text content). An empty element matches a GIS field that is null or empty.
The expected outcome is a conforming locationValidation result with cae:STP appearing
in <valid>, confirming the empty-element match behavior. The civic address matches a
provisioned SSAP record.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr"
                  xmlns:cae="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr:ext"
                  xml:lang="en-US">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <cae:STP></cae:STP>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>