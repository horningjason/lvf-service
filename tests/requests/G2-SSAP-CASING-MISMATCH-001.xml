<?xml version="1.0" encoding="UTF-8"?>
<!--
SSAP match on Capitol Way 1661 with A2 submitted as "Burleigh county" (lowercase 'c').

Gate 2 comparison is case-insensitive, so all nine elements validate successfully.
However, the submitted A2 does not exactly match the canonical GIS value "Burleigh County",
so completeLocation is not suppressed. completeLocation is returned containing the full
GIS record with canonical casing, giving the client correctly-cased values.

Companion to G2-SSAP-CASING-EXACT-001, which submits the same address with exact
GIS casing and confirms completeLocation is suppressed.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh county</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
      <PCN>Bismarck</PCN>
      <PC>58501</PC>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
