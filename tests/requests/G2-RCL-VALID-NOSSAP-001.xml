<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with sub-unit elements (UNIT_PRETYPE=Unit,
UNIT_VALUE=11) at an address for which no matching SSAP record exists for this specific
unit. The SSAP progressive filter finds no single match; the algorithm falls through to
RCL, which matches the street segment. The expected outcome is a conforming
locationValidation result with street administrative and name elements in <valid>;
ca:HNO, UNIT_PRETYPE, and UNIT_VALUE are <unchecked> per INF-027 §2.5.8.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr" 
                  xmlns:cdx2="urn:nena:xml:ns:pidf:nenaCivicAddr2"
                  xml:lang="en-US" >
      <country>US</country>
      <A1>ND</A1>
      <A2>Mercer County</A2>
      <A3>Beulah</A3>
      <RD>3RD</RD>
      <STS>Avenue</STS>
      <POD>Northwest</POD>
      <HNO>205</HNO>
      <cdx2:UNIT_PRETYPE>Unit</cdx2:UNIT_PRETYPE>
      <cdx2:UNIT_VALUE>11</cdx2:UNIT_VALUE>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>