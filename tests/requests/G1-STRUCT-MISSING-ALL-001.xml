<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address missing the required country, A1, and A2 elements.
Gate 1 requires all three to be present and non-empty; the first missing element
(country) triggers a <locationInvalid> error response.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr" xml:lang="en-US" >
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
	    <STS>Way</STS>
	    <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>