<?xml version="1.0" encoding="UTF-8"?>
<!--
Extension — rli:returnAdditionalLocation="complete" on an RCL-path address.

State Street, Bismarck, HNO 3401 produces an RCL match (no SSAP record exists for
this address). The submission omits PCN and PC. The matched RCL segment has
PostComm_R=Bismarck and PostCode_R=58503, both absent from the submission.

Expected: RCL match with HNO unchecked, and <rli:completeLocation> adding PCN and PC.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1"
             xmlns:rli="urn:ietf:params:xml:ns:lost-rli1"
             validateLocation="true"
             rli:returnAdditionalLocation="complete">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>State</RD>
      <STS>Street</STS>
      <HNO>3401</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
