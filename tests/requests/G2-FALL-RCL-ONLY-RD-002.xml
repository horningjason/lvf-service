<?xml version="1.0" encoding="UTF-8"?>
<!--
Same as G2-FALL-RCL-ONLY-RD-001 but submitting PC instead of PCN. Highway 83 (STP=Highway,
RD=83) exists in RCL for A3=Bismarck but has no SSAP records. SSAP fails at ca:RD and
is discarded; RCL validates through RD and STP but fails at HNO=3401 (below all segment
ranges). Result: invalid at ca:HNO.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr"
                  xmlns:cae="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr:ext"
                  xml:lang="en-US">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <cae:STP>Highway</cae:STP>
      <RD>83</RD>
      <HNO>3401</HNO>
      <PC>58503</PC>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
