<?xml version="1.0" encoding="UTF-8"?>
<!--
Protocol — <asOf> with a datetime beyond all provisioned service boundary
expiration dates causes a <serviceNotImplemented> response.

This request submits a future <asOf> of 2199-05-15T00:00:00Z. The provisioned
service boundary for this address expires 2198-12-31. When the LVF applies the
<asOf> timestamp as the temporal reference for boundary selection, no valid
(non-expired) boundary exists as of that date, producing <serviceNotImplemented>.

This confirms that temporal filtering applies to service boundaries during <asOf>
processing — the LVF does not silently fall back to the current boundary when
the requested future time falls outside its validity window.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1"
             xmlns:planned="urn:ietf:params:xml:ns:lostPlannedChange1"
             validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
  <planned:asOf>2199-05-15T00:00:00Z</planned:asOf>
</findService>
