<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address with an empty HNO element (tag present, no text
content). Gate 1 requires HNO to be present and non-empty; an empty string fails this
check and produces a <locationInvalid> error response. This is distinct from a
non-integer HNO (validate_23), which passes Gate 1 but fails in Gate 2.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO></HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
