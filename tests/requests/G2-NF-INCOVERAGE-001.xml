<?xml version="1.0" encoding="UTF-8"?>
<!--
Gate 2 — street exists in GIS but submitted HNO is outside all RCL address ranges.

Knudsen Avenue in Bismarck has RCL segments with address ranges up to a maximum
of ToAddr_R=4099. HNO=4200 is above that maximum. No SSAP record exists for
Knudsen Avenue HNO 4200.

The progressive filter succeeds through country / A1 / A2 / A3 / RD / STS.
At the HNO step, SSAP finds no matching record and RCL finds no segment whose
range includes 4200. Stop-on-first-invalid fires at ca:HNO.

NOTE: The NF prefix in this test's name describes the scenario (no valid address
found at this HNO), not the response type. The result is <invalid> at ca:HNO,
not a <notFound> error response — stop-on-first-invalid always produces <invalid>
at the failing element regardless of the reason the filter exhausted candidates.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Knudsen</RD>
      <STS>Avenue</STS>
      <HNO>4200</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
