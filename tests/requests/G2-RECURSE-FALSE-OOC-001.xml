<?xml version="1.0" encoding="UTF-8"?>
<!--
Gate 2 — out-of-coverage admin failure with explicit recursive="false" → <redirect>.

Cass County is outside this LVF's civic coverage region. Gate 2 fails at ca:A2
(no GIS records match US / ND / Cass County). The civic coverage lookup also
yields no match — Cass County is outside this LVF's coverage region.

The client explicitly sets recursive="false". The LVF behavior is identical to
the default (recursive attribute absent): it returns <redirect> to the parent LVF.

Companion to G2-REDIRECT-OOC-A2-001, which tests the same scenario with the
recursive attribute absent. This test confirms that recursive="false" is correctly
parsed and does not alter the redirect path.

REQUIRES A RUNNING PARENT LVF: LVF_PARENT_URI must point to a reachable parent LVF
instance provisioned with Cass County GIS data.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true" recursive="false">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Cass County</A2>
      <A3>Fargo</A3>
      <RD>Main</RD>
      <STS>Avenue</STS>
      <HNO>100</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
