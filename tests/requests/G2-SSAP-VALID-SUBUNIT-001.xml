<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a valid civic address with sub-unit elements (UNIT_PRETYPE and
UNIT_VALUE) that uniquely identify a provisioned SSAP record. The expected outcome
is a conforming locationValidation result with all submitted elements, including the
sub-unit fields, in <valid>.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr"
                  xmlns:cdx2="urn:nena:xml:ns:pidf:nenaCivicAddr2"
                  xml:lang="en-US">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <PRD>North</PRD>
      <RD>19th</RD>
      <STS>Street</STS>
      <HNO>3420</HNO>
      <cdx2:UNIT_PRETYPE>Unit</cdx2:UNIT_PRETYPE>
      <cdx2:UNIT_VALUE>11</cdx2:UNIT_VALUE>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>