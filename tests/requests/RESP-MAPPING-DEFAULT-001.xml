<?xml version="1.0" encoding="UTF-8"?>
<!--
Gate 2 — admin-level failure at ca:country outside civic coverage → <redirect>.

REQUIRES A RUNNING PARENT LVF: LVF_PARENT_URI must point to a reachable parent
LVF instance.

Country code CA has no provisioned boundary and no civic coverage region entry.
Gate 2 fails at ca:country (no SSAP or RCL records match CA). Because the failure
is at an admin element outside coverage and LVF_PARENT_URI is configured, the
response is <redirect> to the parent LVF.

This test originally exercised the defaultMappingReturned fallback path before
the redirect rule was implemented. The redirect rule takes precedence: when an
out-of-coverage admin failure occurs and a parent LVF is configured, the client
is redirected rather than receiving a synthetic default mapping.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>CA</country>
      <A1>ON</A1>
      <A2>York Region</A2>
      <A3>Markham</A3>
      <RD>Main</RD>
      <STS>Street</STS>
      <HNO>100</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
