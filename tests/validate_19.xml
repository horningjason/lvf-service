<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address that includes LOC (Additional Location Information)
and PLC (Place Type) elements. Per §5.5.1, LOC and PLC are always-unchecked elements
that are never evaluated by the progressive filter regardless of the matched layer.
The expected outcome is a conforming locationValidation result with standard civic
elements in <valid> and both ca:LOC and ca:PLC in <unchecked>. The civic address
matches a provisioned SSAP record.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
      <LOC>Near the fountain</LOC>
      <PLC>Residence</PLC>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
