      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:fire</service>
</findService>
