<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address using a highway route number as the road name
(RD=83) with STP=Highway, representing a naming convention not found in the provisioned
GIS data. The LVF performs no alias resolution. Gate 2 fails at ca:RD; subsequent
elements (cae:STP, ca:HNO, ca:PC) are <unchecked> per the stop-on-first-invalid rule.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr"
                  xmlns:cae="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr:ext"
                  xml:lang="en-US">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <cae:STP>Highway</cae:STP>
      <RD>83</RD>
      <HNO>3401</HNO>
      <PC>58503</PC>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
</findService>
