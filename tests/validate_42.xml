<?xml version="1.0" encoding="UTF-8"?>
<!--
Protocol — <asOf> element is rejected with <badRequest>.

The draft-ietf-ecrit-lost-planned-changes extension defines an <asOf> element that
clients can include to request data as of a specific point in time. This LVF does
not support asOf queries — a future-dated asOf could yield a different result than
the current dataset if future-effective records are provisioned, and silently
returning current data would be misleading. Requests containing a planned:asOf
element are therefore rejected.

This request includes <planned:asOf>2025-01-01T00:00:00Z</planned:asOf>. The expected
outcome is a <badRequest> error response.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1"
             xmlns:planned="urn:ietf:params:xml:ns:lostPlannedChange1"
             validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr">
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>
      <RD>Capitol</RD>
      <STS>Way</STS>
      <HNO>1661</HNO>
    </civicAddress>
  </location>
  <service>urn:service:sos</service>
  <planned:asOf>2025-01-01T00:00:00Z</planned:asOf>
</findService>
