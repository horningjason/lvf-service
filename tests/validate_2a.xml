<?xml version="1.0" encoding="UTF-8"?>
<!--
This request submits a civic address missing the required HNO element, alongside a
geodetic <gml:Point>. The geodetic data is silently ignored. Gate 1 requires HNO to
be present and non-empty; its absence produces a <locationInvalid> error response.
-->
<findService xmlns="urn:ietf:params:xml:ns:lost1" validateLocation="true">
  <location id="L1" profile="civic">
    <civicAddress xmlns="urn:ietf:params:xml:ns:pidf:geopriv10:civicAddr" xml:lang="en-US" >
      <country>US</country>
      <A1>ND</A1>
      <A2>Burleigh County</A2>
      <A3>Bismarck</A3>    
      <RD>Capitol</RD>
	    <STS>Way</STS>
    </civicAddress>
	<gml:Point xmlns:gml="http://www.opengis.net/gml" srsName="urn:ogc:def:crs:EPSG::4326">
		<gml:pos>46.844881 -100.834272</gml:pos>
	</gml:Point>
  </location>
  <service>urn:service:sos</service>
</findService>