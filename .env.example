# Server Identity
# ---------------
# LoST server URI placed in <path><via source="..."> and <errors source="...">.
LVF_SERVER_URI=lostserver.example.com

# DNS-style identifier of the agency operating this LVF instance.
# Populates the agencyId field of LostQueryLogEvent and LostResponseLogEvent.
# Required for conformant i3 logging; a WARNING is logged at startup if unset.
# Example: nd911.nd.gov
# LVF_AGENCY_ID=

# xml:lang value on <displayName> elements in mapping responses (default: en)
LVF_DISPLAY_NAME_LANG=en

# Log level for all LVF loggers (src.*). Valid values: DEBUG, INFO, WARNING, ERROR.
# Does not affect uvicorn's own access log. Defaults to INFO.
LVF_LOG_LEVEL=INFO


# GIS Data
# --------
# Path to the GeoPackage containing all GIS layers.
# If absent or the file does not exist, the server starts in routing-only mode:
# Gate 0/1/2 are bypassed and all /lost requests are routed to child coverage
# store entries or LVF_PARENT_URI. Useful for pure routing nodes.
LVF_GPKG_PATH=data/child_lvf_data.gpkg

# GeoPackage layer names (defaults shown)
LVF_SSAP_LAYER=SiteStructureAddressPoint
LVF_RCL_LAYER=RoadCenterLine
LVF_BOUNDARY_LAYERS=PsapPolygon

# How often (seconds) the server polls the GeoPackage for changes and triggers
# a hot reload. Set to 0 to disable the watcher entirely. (default: 60)
LVF_GPKG_POLL_INTERVAL_SECONDS=60

# sourceId for the synthetic default mapping emitted when civic coverage lookup
# fails (no geographic authority). Required when LVF_GPKG_PATH is set; not needed
# in routing-only mode. Use a nil UUID to signal this is not a real PSAP boundary.
LVF_DEFAULT_MAPPING_SOURCE_ID={00000000-0000-0000-0000-000000000000}


# LoST Service
# ------------
# Comma-separated URN(s) treated as aliases for urn:service:sos. Gate 0
# accepts them; the response <mapping> echoes the requested URN rather than
# the provisioned one. Leave unset if no aliases are needed.
LVF_SOS_ALIAS_URNS=urn:emergency:service:sos.psap


# Tree Topology & LoST-Sync (RFC 6739)
# -------------------------------------
# DNS name (RFC 5222 appUniqueString format) of the parent LoST server to
# redirect out-of-coverage queries to. When set, Gate 2 failures at an admin
# element (country/A1–A5) that fall outside this LVF's civic coverage region
# return <redirect target="..." source="..."> instead of <notFound>. Leave
# unset if this LVF has no parent (out-of-coverage queries return <notFound>).
# LVF_PARENT_URI=parent.lvf.example.com

# Comma-separated list of child LVF /sync endpoint URLs this node should pull
# from on startup. When set, this node acts as a parent and stores received
# coverage regions in the child coverage store (lvf_child_coverage.json).
# Incoming /lost requests are checked against child coverage regions before
# Gate 0; matches redirect or recurse to the appropriate child.
# Leave unset if this node has no children.
# LVF_SYNC_CHILDREN=http://192.168.1.10:8000/sync,http://192.168.1.11:8000/sync

# Stable UUID used as sourceId when pushing this node's civic coverage region
# to LVF_PARENT_URI/sync on startup (and after GIS hot-reload). Must remain
# constant across restarts. Required for push; unused if LVF_PARENT_URI is unset.
# LVF_SYNC_SOURCE_ID_CIVIC={11111111-1111-1111-1111-111111111111}

# Stable UUID used as sourceId when pushing this node's geodetic coverage region
# to LVF_PARENT_URI/sync on startup (and after GIS hot-reload). Must remain
# constant across restarts. Required for push; unused if LVF_PARENT_URI is unset.
# LVF_SYNC_SOURCE_ID_GEODETIC={22222222-2222-2222-2222-222222222222}


# Root AMS Mode
# -------------
# Set LVF_ROOT_AMS=true on a root Authoritative Mapping Server (AMS) node.
# When active:
#   - Programmatic GIS-derived push to LVF_PARENT_URI is suppressed entirely.
#   - Operator-declared coverage is pushed to LVF_FOREST_GUIDE_URI instead.
#   - Out-of-coverage redirect/recursion via LVF_PARENT_URI is unchanged.
#   - Coverage changes received from children cascade upstream automatically.
# Leave unset (or false) on child, intermediate, and Forest Guide nodes.
# LVF_ROOT_AMS=true

# Full /sync URL of the Forest Guide this root AMS should push coverage to.
# Only used when LVF_ROOT_AMS=true. Must include the /sync path.
# Example (Docker Compose multi-container setup):
# LVF_FOREST_GUIDE_URI=http://host.docker.internal:8002/sync

# When LVF_ROOT_AMS=true, two provisioning files must exist in the same
# directory as LVF_GPKG_PATH (or in the working directory if no GPKG):
#
#   ams_civic_coverage.json
#     JSON array of civic tuples. Each object may contain: country, A1, A2,
#     A3, A4, A5. "country" is required. Absent fields = wildcard at the FG.
#     Example: [{"country":"US","A1":"ND","A2":"Burleigh County"}]
#
#   ams_geodetic_coverage.geojson
#     GeoJSON Polygon or MultiPolygon representing the jurisdictional boundary.
#     For MultiPolygon, the largest polygon by area is used. GeoJSON is the
#     input format only — the wire format to the FG is always GML.
#
# Both files are validated at startup and re-read on every GIS hot-reload.
# Replace the files and touch the GeoPackage to update declared coverage
# without restarting the service.


# Forest Guide Mode
# -----------------
# Set LVF_FOREST_GUIDE_MODE=true to run this node as a Forest Guide.
# In this mode: GIS validation is skipped; all requests are redirected to the
# matching child LVF via the child coverage store (populated via LVF_SYNC_CHILDREN);
# LVF_PARENT_URI is ignored (Forest Guides have no parent per RFC 5582 §8).
# LVF_FOREST_GUIDE_MODE=true


# NTP
# ---
# Hostname of the NTP server to use for time synchronization.
# When unset (the default), NTP is disabled and the system clock is used silently.
# Set this variable to enable NTP. Example:
# LVF_NTP_SERVER=pool.ntp.org
#
# NTP protocol version (default: 3)
# LVF_NTP_VERSION=3
#
# NTP query timeout in seconds (default: 5.0)
# LVF_NTP_TIMEOUT=5.0


# i3 Logging (NENA-STA-010.3.1 ��4.12.3)
# ---------------------------------------
# URI of an i3 Logging Service to POST LogEvents to.
# When unset, log events are emitted to Python standard logging (stdout) only.
# LVF_LOGGING_SERVICE_URI=https://logging.example.com/LogEvents


# SIP State Notifications (ElementState / ServiceState)
# -------------------------------------------------------
# Enables the i3 SUBSCRIBE/NOTIFY notifier interface per NENA-STA-010.3.1
# §2.4.1 (ElementState) and §2.4.2 (ServiceState). When LVF_SIP_PORT is set
# and non-zero, the LVF listens for SIP SUBSCRIBE on UDP and TCP and sends
# SIP NOTIFY to subscribers when health state changes. In production, place
# this interface on the ESInet SIP network, separate from the HTTPS LoST
# interface. Set LVF_SIP_PORT=0 (or leave it unset) to disable entirely.
#
# IP address or hostname to bind the SIP listener (default: 0.0.0.0)
# LVF_SIP_HOST=0.0.0.0
#
# SIP port number. Set to 0 to disable the SIP listener. (default: 5060)
# LVF_SIP_PORT=5060
#
# Comma-separated SIP URIs permitted to subscribe. When unset or empty, all
# SUBSCRIBE requests are accepted (appropriate for ESInet trust model where
# network-level access control is assumed).
# LVF_SIP_ALLOWED_SUBSCRIBERS=sip:esrp.example.com


# Discrepancy Reporting (NENA-STA-010.3.1 §3.7.1, §3.7.5, §3.7.11)
# ------------------------------------------------------------------
# HTTP endpoint to POST Discrepancy Reports to (the responding agency's
# .../Reports web service). When unset, DRs are logged locally only.
# LVF_DR_ENDPOINT=https://dr.example.com/Reports
#
# URI the responding agency uses to send DR resolutions back to this LVF.
# Used as resolutionUri in the DR body. Required for conformant submission.
# LVF_DR_RESOLUTION_URI=https://lvf.example.com/dr-resolution
#
# Contact name for the DR jCard (reportingContactJcard). Defaults to
# "LVF Administrator" if unset. A WARNING is logged at startup if unset.
# LVF_DR_CONTACT_NAME=LVF Administrator
#
# Contact email for the DR jCard. A WARNING is logged at startup if unset.
# LVF_DR_CONTACT_EMAIL=admin@example.com
