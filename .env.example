# Path to the GeoPackage containing all GIS layers.
# If absent or the file does not exist, the server starts in routing-only mode:
# Gate 0/1/2 are bypassed and all /validate requests are routed to child coverage
# store entries or LVF_PARENT_URI. Useful for pure routing nodes.
LVF_GPKG_PATH=data/child_lvf_data.gpkg

# GeoPackage layer names (defaults shown)
LVF_SSAP_LAYER=SiteStructureAddressPoint
LVF_RCL_LAYER=RoadCenterLine
LVF_BOUNDARY_LAYERS=PsapPolygon

# How often (seconds) the server polls the GeoPackage for changes and triggers
# a hot reload. Set to 0 to disable the watcher entirely. (default: 60)
LVF_GPKG_POLL_INTERVAL_SECONDS=60

# Log level for all LVF loggers (src.*). Valid values: DEBUG, INFO, WARNING, ERROR.
# Does not affect uvicorn's own access log. Defaults to INFO.
LVF_LOG_LEVEL=INFO

# LoST server identity placed in <path><via source="..."> and <errors source="...">
LVF_SERVER_URI=lostserver.example.com

# xml:lang value on <displayName> elements in mapping responses (default: en)
LVF_DISPLAY_NAME_LANG=en

# sourceId for the synthetic default mapping emitted when civic coverage lookup
# fails (no geographic authority). Required when LVF_GPKG_PATH is set; not needed
# in routing-only mode. Use a nil UUID to signal this is not a real PSAP boundary.
LVF_DEFAULT_MAPPING_SOURCE_ID={00000000-0000-0000-0000-000000000000}

# Comma-separated URN(s) treated as aliases for urn:service:sos. Gate 0
# accepts them; the response <mapping> echoes the requested URN rather than
# the provisioned one. Leave unset if no aliases are needed.
# LVF_SOS_ALIAS_URNS=urn:emergency:service:sos.psap

# DNS name (RFC 5222 appUniqueString format) of the parent LoST server to
# redirect out-of-coverage queries to. When set, Gate 2 failures at an admin
# element (country/A1–A5) that fall outside this LVF's civic coverage region
# return <redirect target="..." source="..."> instead of <notFound>. Leave
# unset if this LVF has no parent (out-of-coverage queries return <notFound>).
# LVF_PARENT_URI=parent.lvf.example.com

# LoST-Sync (RFC 6739) — coverage region synchronization
# -------------------------------------------------------

# Comma-separated list of child LVF /sync endpoint URLs this node should pull
# from on startup. When set, this node acts as a parent and stores received
# coverage regions in the child coverage store (lvf_child_coverage.json).
# Incoming /validate requests are checked against child coverage regions before
# Gate 0; matches redirect or recurse to the appropriate child.
# Leave unset if this node has no children.
# LVF_SYNC_CHILDREN=http://192.168.1.10:8000/sync,http://192.168.1.11:8000/sync

# Stable UUID used as sourceId when pushing this node's civic coverage region
# to LVF_PARENT_URI/sync on startup (and after GIS hot-reload). Must remain
# constant across restarts. Required for push; unused if LVF_PARENT_URI is unset.
# LVF_SYNC_SOURCE_ID_CIVIC={11111111-1111-1111-1111-111111111111}

# Stable UUID used as sourceId when pushing this node's geodetic coverage region
# to LVF_PARENT_URI/sync on startup (and after GIS hot-reload). Must remain
# constant across restarts. Required for push; unused if LVF_PARENT_URI is unset.
# LVF_SYNC_SOURCE_ID_GEODETIC={22222222-2222-2222-2222-222222222222}
